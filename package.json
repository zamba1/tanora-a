    "@lexical/react": "^0.35.0",
    "@lottiefiles/dotlottie-react": "^0.14.3",
    "@mui/lab": "^7.0.0-beta.12",
    "@mui/material": "^7.1.0",
    "@mui/material-nextjs": "^7.1.0",
    "@mui/x-data-grid": "^8.4.0",
    "@mui/x-date-pickers": "^8.4.0",
    "@mui/x-tree-view": "^8.4.0",
